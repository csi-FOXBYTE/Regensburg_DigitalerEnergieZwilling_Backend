@startuml
!theme plain

title DEZ MVP Roadmap - Release-Aufteilung
top to bottom direction

skinparam shadowing false
skinparam defaultFontName Arial
skinparam rectangle {
  RoundCorner 12
  BorderColor #1F2937
  FontColor #111827
}
skinparam ArrowColor #1F2937

rectangle "Release 1\n02.03.2026 - 15.03.2026\n---\nPlattformaufbau\nCIVITAS/CORE Basis\nServices\nDatenpipeline + Preprocessing\nMasterPortal Link-Out" as R1 #DCEBFF

rectangle "Release 2\n16.03.2026 - 12.04.2026\n---\nHauptzielgruppe\nÖffentlicher 3D-Client\nGebäudeauswahl + Berechnung\nIst-Zustand + Vergleich\nBackend CRUD" as R2 #DFF7E2

rectangle "Release 3\n13.04.2026 - 10.05.2026\n---\nNebenzielgruppe + Abschluss\nSanierungsmaßnahmen\nZusammenfassung + Bürger-Export\nDatenpersistenz in Navigation\nAnzeigetexte\nVerwaltungsbereich + Wärmeplanung" as R3 #FFEFD6

rectangle "Release 4\n11.05.2026 - 18.06.2026\n---\nErweiterungen + Stabilisierung\nAmortisation\nFeedback-Funktion\nPotenzial-Farbvisualisierung\nFehlermeldungen\nWhitelabel-Doku\nQuartiersanalyse" as R4 #F3F4F6

rectangle "Inbetriebnahme\n19.06.2026 - 24.07.2026\n---\nRollout\nÜbergang in den Regelbetrieb" as GO #FFF4BF

R1 --> R2 : baut auf
R2 --> R3 : erweitert
R3 --> R4 : erweitert
R4 --> GO : uebergang

legend right
  Quelle: docs/roadmap/mvp-definition.md
  Stand: 2026-04-14
endlegend

@enduml
