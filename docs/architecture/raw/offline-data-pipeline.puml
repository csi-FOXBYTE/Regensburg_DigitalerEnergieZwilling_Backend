@startuml
left to right direction
skinparam rectangle {
  BackgroundColor #F7F7F7
  BorderColor #444444
}

title Offline-Datenpipeline

rectangle "LOD2 Daten\n(CityGML, inkl. Adressen)" as lod2
rectangle "Solarpotenziale\n(3D Tiles + Textur)" as solar
rectangle "Geothermiepotenziale\n(WMS, offen)" as geo
rectangle "Vegetation (Baeume)\n(3D Tiles)" as trees

rectangle "Externer Datendienst\n(S3-kompatibel)" as s3
rectangle "CIVITAS/CORE\n(Airflow Orchestrator)" as airflow
rectangle "Extract-Container\nZIP entpacken" as extract
rectangle "Konvertierungs-Container (Add-on)\nCityGML -> CityJSON" as convert
rectangle "Anreicherungs-Container (Add-on)\nEnrichment auf CityJSON\nSolar (PV) + Geothermie\n+ optionale Kennwerte" as enrich
rectangle "Calculation Core (optional)\nKennwerte auf CityJSON" as calc
rectangle "Export-Container A\nCityJSON -> 3D Tiles" as export_tiles
rectangle "Export-Container B\nCityJSON -> CityGML" as export_gml

rectangle "APISIX\n(Web/API Gateway)" as apisix
rectangle "Tiles Gateway\n(optional)" as gw
rectangle "Public Client" as client

lod2 --> s3
solar --> s3
geo --> s3
trees --> s3

airflow ..> convert : orchestriert
airflow ..> extract : orchestriert
airflow ..> enrich : orchestriert
airflow ..> calc : orchestriert (optional)
airflow ..> export_tiles : orchestriert
airflow ..> export_gml : orchestriert
s3 --> extract : Download input ZIP
extract --> convert : extracted files
convert --> s3 : Upload cityjson/
s3 --> enrich : Download cityjson/
enrich --> s3 : Upload cityjson_enriched/
s3 --> calc : Download cityjson_enriched/
calc --> s3 : Upload cityjson_enriched/ (updated)
s3 --> export_tiles : Download cityjson_enriched/
export_tiles --> s3 : Upload tiles/
s3 --> export_gml : Download cityjson_enriched/
export_gml --> s3 : Upload citygml/

s3 --> apisix : direct mode
apisix --> client : direct mode
s3 --> gw : optional mode
gw --> apisix : optional mode
apisix --> client : optional mode

@enduml
