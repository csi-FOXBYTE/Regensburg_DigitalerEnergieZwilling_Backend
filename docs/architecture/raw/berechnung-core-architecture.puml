@startuml
left to right direction
skinparam rectangle {
  BackgroundColor #F7F7F7
  BorderColor #444444
}

title Berechnungskern - Kontext

rectangle "Frontend\n(Browser)" as frontend
rectangle "Backend\n(Node.js)" as backend
rectangle "Berechnungskern\n(JS-Modul)" as core
rectangle "Konfigurations-Snapshot\n(versioniert)" as config
rectangle "Gebäudedaten\n(Potenziale aus Tiles)" as building
rectangle "Nutzereingaben" as inputs
rectangle "Berechnungsergebnisse\n(Energie, CO₂, Kosten)" as outputs

frontend --> core
backend --> core
config --> core
building --> core
inputs --> core
core --> outputs

@enduml

