@startuml
title Runtime-Flow - Offline-Datenpipeline (vereinfacht)
top to bottom direction

skinparam shadowing false
skinparam backgroundColor white
skinparam rectangle {
  BackgroundColor #F7F7F7
  BorderColor #444444
  FontColor #222222
  RoundCorner 10
}
skinparam ArrowColor #444444

rectangle "Download ZIP File from S3" as A
rectangle "Extract ZIP" as B
rectangle "Convert CityGML to CityJSON" as C
rectangle "Enrich CityJSON + precalculate Energy" as D
rectangle "Generate 3D Tiles from CityJSON" as E
rectangle "Convert CityJSON back to CityGML" as F
rectangle "Upload to S3" as G

A --> B
B --> C
C --> D
D --> E
D --> F
E --> G
F --> G

@enduml
