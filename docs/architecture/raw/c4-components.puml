@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Digitaler Energie Zwilling (DEZ) - C4 Component Diagram

Person(citizen, "Citizen (owners/landlords)")
Person(admin, "City Administration / Staff")

System_Boundary(civitas, "CIVITAS/CORE Platform") {
  System_Boundary(detAddon, "digital-energy-twin_addon (DEZ)") {

    Container(gateway, "APISIX Web/API Gateway", "API Gateway and Reverse Proxy", "Single public entrypoint for frontend, backend APIs, config snapshots and tiles access")

    Container_Boundary(frontend, "Web Frontend Static Site", "Astro SSG") {
      Component(astroSSG, "Astro Static Build", "Astro", "Generates static HTML and island bundles without SSR")
      Component(publicIsland, "Public Client Island", "React and Cesium", "Public 3D viewer and Berechnungs-UI")
      Component(adminIsland, "Admin Island", "React", "Admin area, available only after authentication")
      Component(sharedUI, "Shared UI Components", "React", "Shared design system components")
    }

    Container_Boundary(backend, "Backend API", "Node and Fastify") {
      Component(publicStatic, "Public Static Delivery", "Fastify Static", "Serves public HTML assets and published config file")
      Component(htmlGateway, "Protected Admin HTML Gateway", "Fastify", "Serves admin HTML only for authenticated users")
      Component(apiControllers, "OpenAPI Controllers", "fastify-toab", "Public and admin REST endpoints")
      Component(auth, "Auth Middleware", "OIDC and JWT", "Authentication and authorization enforcement")
      Component(configService, "Configuration Service", "TypeScript JavaScript", "Manages configuration in DB and publishes versioned config files")
      Component(userData, "User Data Service", "TypeScript JavaScript", "Persists user inputs and results and supports triage workflows")
      Component(calcService, "Berechnungsservice", "TypeScript JavaScript", "Optionale serverseitige Berechnungsausführung für Admin oder Fallback")
      Component(geoService, "Geo Query Service", "TypeScript JavaScript", "Spatial queries for admin and data views")
      Component(telemetry, "Observability", "OpenTelemetry", "Tracing metrics and logging")
    }

    Container(calcCore, "Berechnungskern-Modul", "JavaScript Module Package", "Shared module, runs in browser and in Node")

    Container(tilesGateway, "Tiles Gateway (optional)", "HTTP Gateway", "Optional proxy for 3D tiles with caching and range requests")

    SystemDb(db, "DEZ Database (logical)", "PostgreSQL Schema + PostGIS extensions", "Stores user inputs and triage state and configuration source of truth")
  }

  Container_Boundary(pipelineAddon, "offline-data-pipeline_addon (separates CIVITAS/CORE Add-on)", "Airflow + Batch Processing") {
    Component(airflow, "Airflow DAG Orchestrator", "Apache Airflow", "Orchestrates DEZ offline pipeline tasks")
    Component(extract, "Extract-Container", "Batch Container", "Downloads and extracts input ZIP artifacts from external data service")
    Component(convert, "Konvertierungs-Container (Add-on)", "citygml-tools", "Converts CityGML to CityJSON")
    Component(enrich, "Anreicherungs-Container (Add-on)", "GDAL + custom", "Enriches CityJSON with solar and geothermal attributes")
    Component(calcOffline, "Calculation Core (optional)", "JavaScript Module", "Adds optional calculated metrics on enriched CityJSON")
    Component(exportTiles, "Export-Container A", "cityjson-to-3d-tiles", "Exports enriched CityJSON to 3D Tiles")
    Component(exportGml, "Export-Container B", "CityJSON to CityGML Tooling", "Exports enriched CityJSON to CityGML")
  }

  Container(idp, "Keycloak (CIVITAS/CORE)", "OIDC identity provider")
  ContainerDb(platformPostgres, "PostgreSQL Server (CIVITAS/CORE Platform)", "PostgreSQL", "Shared database server operated by the platform")
}
System_Ext(geo, "City Geo Services", "WMS and WMTS basemaps")
System_Ext(staticTiles, "Externer Datendienst (S3-kompatibel)", "External object storage for input artifacts and published outputs")
System_Ext(citygml, "LOD2 Daten (CityGML, inkl. Adressen)", "Input dataset")
System_Ext(solar, "Solarpotenziale (3D Tiles + Textur)", "Input dataset")
System_Ext(geothermal, "Geothermiepotenziale (WMS, offen)", "Input dataset")
System_Ext(vegetation, "Vegetation (Baeume) (3D Tiles)", "External visual layer for public map rendering")

Rel(citizen, gateway, "uses", "HTTPS")
Rel(admin, gateway, "uses", "HTTPS")

Rel(gateway, publicStatic, "routes public site and config", "GET / and GET /config")
Rel(gateway, htmlGateway, "routes admin site", "GET /admin")
Rel(gateway, apiControllers, "routes API", "GET/POST /api (policy and rate limit)")
Rel(gateway, tilesGateway, "routes tiles (optional mode)", "GET /tiles")
Rel(gateway, staticTiles, "routes tiles (direct mode)", "GET /tiles")

Rel(htmlGateway, auth, "enforces authentication")
Rel(auth, idp, "validates tokens")

Rel(astroSSG, publicIsland, "builds static HTML")
Rel(astroSSG, adminIsland, "builds static HTML")

Rel(publicStatic, publicIsland, "delivers public HTML and assets")
Rel(htmlGateway, adminIsland, "delivers admin HTML after login")

Rel(publicIsland, sharedUI, "uses")
Rel(adminIsland, sharedUI, "uses")

Rel(publicIsland, gateway, "loads 3D tiles with embedded potentials", "GET /tiles")
Rel(tilesGateway, staticTiles, "fetches tiles")
Rel(publicIsland, geo, "loads basemaps")
Rel(publicIsland, vegetation, "loads vegetation layer (visual only)")

Rel(publicIsland, publicStatic, "loads published config file", "GET /config/versioned.json")

Rel(publicIsland, calcCore, "imports and runs locally", "privacy option no user data required")
Rel(calcService, calcCore, "imports and runs in Node", "optional admin or fallback execution")

Rel(publicIsland, apiControllers, "sends user inputs for persistence", "REST optional")
Rel(adminIsland, apiControllers, "triages user inputs and manages config", "REST")

Rel(apiControllers, auth, "uses")
Rel(apiControllers, userData, "delegates user data persistence and triage")
Rel(apiControllers, configService, "delegates config management and publishing")
Rel(apiControllers, geoService, "delegates spatial queries")
Rel(apiControllers, calcService, "delegates serverseitige Berechnung", "optional")

Rel(userData, db, "reads and writes user inputs and triage state")
Rel(configService, db, "reads and writes configuration")
Rel(configService, publicStatic, "publishes versioned config file")
Rel(geoService, db, "reads spatial data")
Rel(db, platformPostgres, "hosted on", "schema/database on platform PostgreSQL")

Rel(telemetry, apiControllers, "instruments")
Rel(telemetry, userData, "instruments")
Rel(telemetry, configService, "instruments")
Rel(telemetry, geoService, "instruments")
Rel(telemetry, calcService, "instruments")

Rel(airflow, extract, "orchestrates task")
Rel(airflow, convert, "orchestrates task")
Rel(airflow, enrich, "orchestrates task")
Rel(airflow, calcOffline, "orchestrates task (optional)")
Rel(airflow, exportTiles, "orchestrates task")
Rel(airflow, exportGml, "orchestrates task")

Rel(citygml, staticTiles, "uploads source data")
Rel(solar, staticTiles, "uploads source data")
Rel(geothermal, staticTiles, "uploads source data")
Rel(vegetation, staticTiles, "uploads visual layer data")

Rel(staticTiles, extract, "download input ZIP")
Rel(extract, convert, "extracted files")
Rel(convert, staticTiles, "upload cityjson/")
Rel(staticTiles, enrich, "download cityjson/")
Rel(enrich, staticTiles, "upload cityjson_enriched/")
Rel(staticTiles, calcOffline, "download cityjson_enriched/ (optional)")
Rel(calcOffline, staticTiles, "upload cityjson_enriched/ (updated, optional)")
Rel(staticTiles, exportTiles, "download cityjson_enriched/")
Rel(exportTiles, staticTiles, "upload tiles/")
Rel(staticTiles, exportGml, "download cityjson_enriched/")
Rel(exportGml, staticTiles, "upload citygml/")

note right of auth
OIDC token validation and
role based access control.
end note

note right of apiControllers
Public write path:
Altcha token check, input validation,
server recompute and reject paths.
end note

note bottom of db
No direct client access.
All writes are controlled by backend services.
end note

@enduml
