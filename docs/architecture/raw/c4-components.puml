@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Digitaler Energie Zwilling (DEZ) - C4 Component Diagram (Frontend)

Person(citizen, "Citizen (owners/landlords)")
Person(admin, "City Administration / Staff")

System_Boundary(civitas, "CIVITAS/CORE Platform") {
  System_Boundary(detAddon, "digital-energy-twin_addon (DEZ)") {
    Container(gateway, "APISIX Web/API Gateway", "API Gateway and Reverse Proxy", "Single public entrypoint")

    Container_Boundary(frontend, "Web Frontend Static Site", "Astro SSG") {
      Component(astroSSG, "Astro Static Build", "Astro", "Generates static HTML and island bundles without SSR")
      Component(publicIsland, "Public Client Island", "React and Cesium", "Public 3D viewer and Berechnungs-UI")
      Component(adminIsland, "Admin Island", "React", "Admin area, available only after authentication")
      Component(sharedUI, "Shared UI Components", "React", "Shared design system components")
    }

    Container(backendApi, "Backend API", "Node and Fastify", "REST APIs, static delivery and admin HTML gateway")
    Container(calcCore, "Berechnungskern-Modul", "JavaScript Module Package", "Shared module, runs in browser and in Node")
    Container(tilesGateway, "Tiles Gateway (optional)", "HTTP Gateway", "Optional proxy for 3D tiles")
  }
}

System_Ext(geo, "City Geo Services", "WMS and WMTS basemaps")
System_Ext(staticTiles, "Externer Datendienst (S3-kompatibel)", "External object storage for published outputs")
System_Ext(vegetation, "Vegetation (Baeume) (3D Tiles)", "External visual layer for public map rendering")

Rel(citizen, gateway, "uses", "HTTPS")
Rel(admin, gateway, "uses", "HTTPS")

Rel(gateway, backendApi, "routes public/admin/API", "GET /, GET /admin, GET/POST /api")
Rel(gateway, tilesGateway, "routes tiles (optional mode)", "GET /tiles")
Rel(gateway, staticTiles, "routes tiles (direct mode)", "GET /tiles")

Rel(astroSSG, publicIsland, "builds static HTML")
Rel(astroSSG, adminIsland, "builds static HTML")
Rel(publicIsland, sharedUI, "uses")
Rel(adminIsland, sharedUI, "uses")

Rel(publicIsland, gateway, "loads 3D tiles with embedded potentials", "GET /tiles")
Rel(tilesGateway, staticTiles, "fetches tiles")
Rel(publicIsland, geo, "loads basemaps")
Rel(publicIsland, vegetation, "loads vegetation layer (visual only)")
Rel(publicIsland, backendApi, "loads published config and sends optional user input", "GET /config, REST")
Rel(adminIsland, backendApi, "triages user inputs and manages config", "REST")

Rel(publicIsland, calcCore, "imports and runs locally", "privacy option")

@enduml
