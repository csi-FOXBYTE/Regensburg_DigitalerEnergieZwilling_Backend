@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Digitaler Energie Zwilling (DEZ) - C4 Container Diagram

Person(citizen, "Citizen (owners/landlords)")
Person(admin, "City Administration / Staff")

System_Boundary(civitas, "CIVITAS/CORE Platform") {
  System_Boundary(detAddon, "digital-energy-twin_addon (DEZ)") {

    Container(gateway, "APISIX Web/API Gateway", "API Gateway and Reverse Proxy", "Single public entrypoint for frontend, backend APIs, config snapshots and tiles access")

    Container(frontendPublic, "Public Frontend Static Site", "Astro SSG + nginx", "Static public client for citizens, delivered via nginx")
    Container(frontendAdmin, "Admin Frontend Static Site", "Astro SSG + nginx", "Static admin client for city administration/staff, delivered via nginx")

    Container(backend, "Backend API", "Node.js and Fastify", "APIs for config publish and user data triage; validates APISIX-forwarded access tokens and roles")

    Container(calcCore, "Berechnungskern-Modul", "JavaScript Module Package", "Shared module, runs in browser and in Node")

    Container(tilesGw, "Tiles Gateway (optional)", "HTTP Gateway", "Optional proxy for 3D tiles with caching and range requests")
    ContainerDb(db, "DEZ Database (logical)", "PostgreSQL Schema + PostGIS extensions", "Stores user inputs, triage state and Berechnungskonfigurationen")
  }

  System_Boundary(pipelineAddon, "offline-data-pipeline_addon (separates CIVITAS/CORE Add-on)") {
    Container(airflow, "Airflow Pipeline Orchestrator", "Apache Airflow", "Runs the DEZ offline data pipeline DAG and orchestrates processing containers")
    Container(pipelineWorkers, "Offline Pipeline Workers", "Batch Container Group", "Executes extract, convert, enrich, optional calculation and export steps")
  }

  Container(idp, "Keycloak (CIVITAS/CORE)", "OIDC identity provider")
  ContainerDb(platformPostgres, "PostgreSQL Server (CIVITAS/CORE Platform)", "PostgreSQL", "Shared database server operated by the platform")
}
System_Ext(geo, "City Geo Services", "WMS and WMTS basemaps")
System_Ext(tilesStore, "Externer Datendienst (S3-kompatibel)", "External object storage for input artifacts and published outputs")

System_Ext(citygml, "CityGML LOD2 Source", "Input dataset")
System_Ext(potentials, "Solar (3D Tiles) and Geothermal Sources", "Solar 3D tiles + geothermal WMS/raster data")
System_Ext(vegetation, "Vegetation (Trees)", "3D tiles layer")

Rel(citizen, gateway, "uses", "HTTPS")
Rel(admin, gateway, "uses", "HTTPS")

Rel(gateway, frontendPublic, "routes public site", "GET /")
Rel(gateway, frontendAdmin, "routes admin site", "GET /admin")
Rel(gateway, backend, "routes API", "GET/POST /api (authz and policy)")
Rel(gateway, tilesGw, "routes tiles (optional mode)", "GET /tiles")
Rel(gateway, tilesStore, "routes tiles (direct mode)", "GET /tiles")

Rel(gateway, idp, "obtains/validates tokens", "OIDC/JWT")

Rel(frontendPublic, calcCore, "imports and runs", "browser runtime")
Rel(frontendAdmin, calcCore, "imports and runs", "browser runtime optional")
Rel(backend, calcCore, "imports and runs", "Node runtime optional")

Rel(frontendPublic, geo, "loads basemaps", "WMS or WMTS")
Rel(frontendPublic, gateway, "loads 3D tiles with embedded potentials", "GET /tiles")
Rel(tilesGw, tilesStore, "fetches tiles", "HTTP")

Rel(backend, db, "reads and writes", "SQL")
Rel(db, platformPostgres, "hosted on", "schema/database on platform PostgreSQL")
Rel(frontendPublic, backend, "calls API for user data", "REST via APISIX")
Rel(frontendAdmin, backend, "calls API for admin actions", "REST via APISIX")

Rel(airflow, pipelineWorkers, "orchestrates DAG tasks")

Rel(citygml, tilesStore, "uploads source data")
Rel(potentials, tilesStore, "uploads source data")
Rel(vegetation, tilesStore, "uploads visual layer data")

Rel(tilesStore, pipelineWorkers, "reads source artifacts and intermediate data")
Rel(pipelineWorkers, tilesStore, "writes cityjson, enriched data, tiles and citygml")

note right of gateway
Security controls:
- Single external entrypoint
- Route isolation for public/admin
- Rate limiting and policy enforcement
end note

note right of db
Database is not public.
Access only via backend API.
end note

@enduml
